# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Binance API (necesario para live trading; para paper trading solo se usan precios públicos)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Usuarios autorizados (IDs de Telegram separados por coma)
ALLOWED_USERS=123456789,987654321

# Modo de trading: "paper" (simulado) o "live" (real con fondos de Binance)
TRADING_MODE=paper

# Usar testnet de Binance (solo para live trading en pruebas)
USE_TESTNET=false

# Moneda de cotización
QUOTE_CURRENCY=USDT

# Intervalo de verificación de alertas (segundos)
ALERT_CHECK_INTERVAL=30

# Coins monitoreadas por defecto para señales
WATCHLIST_DEFAULT=BTC,ETH,BNB,SOL,ADA,XRP,DOGE,AVAX,MATIC,LINK
